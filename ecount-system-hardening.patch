diff --git a/runtime_paths.py b/runtime_paths.py
new file mode 100644
--- /dev/null
+++ b/runtime_paths.py
@@ -0,0 +1,35 @@
+from __future__ import annotations
+
+import os
+from pathlib import Path
+
+APP_NAME = "ecount-system"
+
+
+def _resolve_runtime_root() -> Path:
+    explicit = os.environ.get("ECOUNT_SYSTEM_HOME") or os.environ.get("YIKAN_APP_HOME")
+    if explicit:
+        return Path(explicit).expanduser()
+    if os.name == "nt":
+        base = os.environ.get("APPDATA") or str(Path.home() / "AppData" / "Roaming")
+    else:
+        base = os.environ.get("XDG_CONFIG_HOME") or str(Path.home() / ".config")
+    return Path(base) / APP_NAME
+
+
+def _ensure_dir(path: Path) -> Path:
+    path.mkdir(parents=True, exist_ok=True)
+    return path
+
+
+APP_RUNTIME_DIR = _ensure_dir(_resolve_runtime_root())
+APP_LOG_DIR = _ensure_dir(APP_RUNTIME_DIR / "logs")
+
+CONFIG_FILE = str(APP_RUNTIME_DIR / "config.json")
+BASE_DATA_DB_FILE = str(APP_RUNTIME_DIR / "base_data.db")
+BASE_DATA_DIR = str(APP_RUNTIME_DIR / "基础数据" / "基础数据")
+
+
+def runtime_file(name: str) -> str:
+    return str(APP_RUNTIME_DIR / name)
diff --git a/migrate_runtime_state.py b/migrate_runtime_state.py
new file mode 100644
--- /dev/null
+++ b/migrate_runtime_state.py
@@ -0,0 +1,49 @@
+from __future__ import annotations
+
+import shutil
+from pathlib import Path
+
+from runtime_paths import APP_RUNTIME_DIR
+
+
+FILES_TO_MOVE = [
+    "config.json",
+    "config.json.bak",
+    "base_data.db",
+    "reconciliation.db",
+    "shipping.bd",
+    "reconciliation_header_mapping.json",
+]
+
+
+def migrate(repo_root: Path) -> None:
+    APP_RUNTIME_DIR.mkdir(parents=True, exist_ok=True)
+    for name in FILES_TO_MOVE:
+        src = repo_root / name
+        dst = APP_RUNTIME_DIR / name
+        if not src.exists():
+            continue
+        if dst.exists():
+            print(f"[skip] {name} already exists at runtime dir: {dst}")
+            continue
+        shutil.copy2(src, dst)
+        print(f"[ok] migrated {name} -> {dst}")
+
+
+if __name__ == "__main__":
+    migrate(Path(__file__).resolve().parent)
